<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0F111A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Colony Statistics"
        android:textColor="#00FFCC"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#1A1D29"
        app:cardCornerRadius="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/stat_total_crew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Crew: 0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/stat_total_xp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Crew XP: 0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/stat_total_missions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Missions Run: 0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/stat_total_wins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Wins: 0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/stat_total_training"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Training Sessions: 0"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#1A1D29"
        app:cardCornerRadius="8dp">

        <com.example.oopproject.ui.view.SimplePieChartView
            android:id="@+id/simple_pie_chart"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btn_crew_reference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crew Reference Guide"
        android:backgroundTint="#00FFCC"
        android:textColor="#000000"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_stats_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back to Base"
        android:backgroundTint="#00FFCC"
        android:textColor="#000000" />

</LinearLayout>