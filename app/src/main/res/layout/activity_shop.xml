<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <TextView
        android:id="@+id/text_shop_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STATION BLACK MARKET"
        android:textColor="#00FF00"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/text_credits_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CREDITS: 5"
        android:textColor="#FFFF00"
        android:textSize="18sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ATK Potion Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:padding="8dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/item_atk_potion" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attack Potion"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+2 Atk next mission"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_buy_atk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 CR"
                    android:backgroundTint="#2E7D32" />
            </LinearLayout>

            <!-- HP Potion Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:padding="8dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/item_hp_potion" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HP Potion"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+3 Max HP next mission"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_buy_hp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 CR"
                    android:backgroundTint="#2E7D32" />
            </LinearLayout>

            <!-- DEF Potion Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:padding="8dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/item_def_potion" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Defense Potion"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1 Def next mission"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />
                </LinearLayout>
                <Button
                    android:id="@+id/btn_buy_def"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 CR"
                    android:backgroundTint="#2E7D32" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_close_shop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BACK TO SHIP"
        android:layout_marginTop="8dp" />

</LinearLayout>